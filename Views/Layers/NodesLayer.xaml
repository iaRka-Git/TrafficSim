<UserControl x:Class="TrafficSim.Views.Layers.NodesLayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ItemsControl ItemsSource="{Binding VisualNodes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Ellipse Width="{Binding Diameter}" Height="{Binding Diameter}"
                             Fill="Red" Stroke="DarkRed" StrokeThickness="2"
                             Cursor="Hand" Focusable="True">

                        <Ellipse.InputBindings>
                            <KeyBinding Key="Delete" 
                                        Command="{Binding DataContext.DeleteRoadNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" />
                        </Ellipse.InputBindings>

                        <Ellipse.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Властивості перехрестя" 
                                          Command="{Binding DataContext.ShowNodePropertiesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}"/>
                                <Separator />
                                <MenuItem Header="Видалити" 
                                          Command="{Binding DataContext.DeleteRoadNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}"
                                          InputGestureText="Del" />
                            </ContextMenu>
                        </Ellipse.ContextMenu>

                        <Ellipse.RenderTransform>
                            <TranslateTransform X="{Binding ScreenX}" Y="{Binding ScreenY}"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl ItemsSource="{Binding VisibleMobilityJoints}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Rectangle Width="{Binding Diameter}" Height="{Binding Diameter}"
                               Fill="Orange" Stroke="DarkOrange" StrokeThickness="1"
                               Cursor="Hand" Focusable="True">

                        <Rectangle.InputBindings>
                            <KeyBinding Key="Delete" 
                                        Command="{Binding DataContext.DeleteMobilityJointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" />
                        </Rectangle.InputBindings>

                        <Rectangle.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Видалити точку" 
                                          Command="{Binding DataContext.DeleteMobilityJointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}"
                                          InputGestureText="Del" />
                            </ContextMenu>
                        </Rectangle.ContextMenu>

                        <Rectangle.RenderTransform>
                            <TranslateTransform X="{Binding ScreenX}" Y="{Binding ScreenY}"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>