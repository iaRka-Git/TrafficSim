<UserControl x:Class="TrafficSim.Views.MapGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrafficSim.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="ViewportGrid"
          Background="White"
          SizeChanged="ViewportGrid_SizeChanged"
          MouseMove="ViewportGrid_MouseMove"
          MouseWheel="ViewportGrid_MouseWheel"
          MouseRightButtonDown="ViewportGrid_MouseRightButtonDown"
          MouseRightButtonUp="ViewportGrid_MouseRightButtonUp"
          MouseLeave="ViewportGrid_MouseLeave"
          MouseLeftButtonDown="ViewportGrid_MouseLeftButtonDown">

        <Canvas x:Name="MapCanvas">

            <ItemsControl ItemsSource="{Binding VerticalLines}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Line X1="{Binding ScreenPos}" Y1="0" X2="{Binding ScreenPos}" Y2="{Binding DataContext.ViewportHeight, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                              Stroke="#ECECEC" StrokeThickness="0.8" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding HorizontalLines}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Line X1="0" Y1="{Binding ScreenPos}" X2="{Binding DataContext.ViewportWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" Y2="{Binding ScreenPos}" 
                              Stroke="#ECECEC" StrokeThickness="0.8" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding VisualNodes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding ScreenX}" />
                        <Setter Property="Canvas.Top" Value="{Binding ScreenY}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="{Binding Diameter}" Height="{Binding Diameter}" 
                     Fill="#FFE53935" Cursor="Hand"
                     MouseLeftButtonDown="Node_MouseLeftButtonDown"
                     MouseLeftButtonUp="Node_MouseLeftButtonUp"
                     MouseMove="Node_MouseMove"
                     Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">

                            <Ellipse.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Видалити вузол" 
                                  Command="{Binding PlacementTarget.Tag.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}" />
                                </ContextMenu>
                            </Ellipse.ContextMenu>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <ItemsControl ItemsSource="{Binding VisibleMobilityJoints}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding ScreenX}" />
                        <Setter Property="Canvas.Top" Value="{Binding ScreenY}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="{Binding Diameter}" Height="{Binding Diameter}" 
                     Fill="#FF4FC3F7" Cursor="Hand"
                     MouseLeftButtonDown="Node_MouseLeftButtonDown"
                     MouseLeftButtonUp="Node_MouseLeftButtonUp"
                     MouseMove="Node_MouseMove"
                     Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">

                            <Ellipse.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Видалити точку перегину" 
                                  Command="{Binding PlacementTarget.Tag.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}" />
                                </ContextMenu>
                            </Ellipse.ContextMenu>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <Line X1="{Binding StickyAxisX}" Y1="0" X2="{Binding StickyAxisX}" Y2="{Binding ViewportHeight}" 
      Stroke="#444444" StrokeThickness="1.5" />

            <Line X1="0" Y1="{Binding StickyAxisY}" X2="{Binding ViewportWidth}" Y2="{Binding StickyAxisY}" 
      Stroke="#444444" StrokeThickness="1.5" />

            <ItemsControl ItemsSource="{Binding AxisLabels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding ScreenX}" />
                        <Setter Property="Canvas.Top" Value="{Binding ScreenY}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}" Foreground="#2A4D7C" FontSize="10" FontWeight="SemiBold"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>
    </Grid>
</UserControl>