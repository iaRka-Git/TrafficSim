<Window x:Class="TrafficSim.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TrafficSim.ViewModels"
        Title="Редактор міста" Height="600" Width="800">

    <Window.DataContext>
        <vm:EditorViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="ViewportGrid" Grid.Row="0"
              Background="White"
              SizeChanged="ViewportGrid_SizeChanged"
              MouseMove="ViewportGrid_MouseMove"
              MouseWheel="ViewportGrid_MouseWheel"
              MouseRightButtonDown="ViewportGrid_MouseRightButtonDown"
              MouseRightButtonUp="ViewportGrid_MouseRightButtonUp"
              MouseLeave="ViewportGrid_MouseLeave">

            <Canvas x:Name="MapCanvas">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding Camera.Zoom}" ScaleY="{Binding Camera.Zoom}" />
                        <TranslateTransform X="{Binding Camera.OffsetX}" Y="{Binding Camera.OffsetY}" />
                    </TransformGroup>
                </Canvas.RenderTransform>
            </Canvas>

            <Canvas IsHitTestVisible="False">

                <ItemsControl ItemsSource="{Binding VerticalLines}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding ScreenPos}" />
                            <Setter Property="Canvas.Top" Value="0" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="0" Y1="0" X2="0" Y2="{Binding DataContext.ViewportHeight, RelativeSource={RelativeSource AncestorType=Window}}" 
                                  Stroke="#ECECEC" StrokeThickness="0.8" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding HorizontalLines}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="0" />
                            <Setter Property="Canvas.Top" Value="{Binding ScreenPos}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="0" Y1="0" X2="{Binding DataContext.ViewportWidth, RelativeSource={RelativeSource AncestorType=Window}}" Y2="0" 
                                  Stroke="#ECECEC" StrokeThickness="0.8" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Line X1="{Binding StickyAxisX}" Y1="0" X2="{Binding StickyAxisX}" Y2="{Binding ViewportHeight}" 
                      Stroke="#444444" StrokeThickness="1.5" />

                <Line X1="0" Y1="{Binding StickyAxisY}" X2="{Binding ViewportWidth}" Y2="{Binding StickyAxisY}" 
                      Stroke="#444444" StrokeThickness="1.5" />

                <ItemsControl ItemsSource="{Binding AxisLabels}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding ScreenX}" />
                            <Setter Property="Canvas.Top" Value="{Binding ScreenY}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" Foreground="#2A4D7C" FontSize="10" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Canvas>
        </Grid>

        <StatusBar Grid.Row="1" Background="#EEE">
            <StatusBarItem>
                <TextBlock Text="Координати курсора: " FontWeight="Bold"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding LogicalCursorPosition.X, StringFormat='X: {0:F0}'}" Width="70"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding LogicalCursorPosition.Y, StringFormat='Y: {0:F0}'}" Width="70"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding Camera.Zoom, StringFormat='Масштаб: {0:F1}x'}" Width="100"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>