<UserControl x:Class="TrafficSim.Views.Layers.GridAxesLayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">
    <Grid>
        <Canvas>
            <Line X1="0" Y1="{Binding StickyAxisY}" 
                  X2="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                  Y2="{Binding StickyAxisY}" 
                  Stroke="Black" StrokeThickness="2"/>

            <Line X1="{Binding StickyAxisX}" Y1="0" 
                  X2="{Binding StickyAxisX}" 
                  Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                  Stroke="Black" StrokeThickness="2"/>
        </Canvas>

        <ItemsControl ItemsSource="{Binding AxisLabels}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock x:Name="TxtMark" Text="{Binding Text}" FontSize="10">
                        <TextBlock.RenderTransform>
                            <TranslateTransform X="{Binding ScreenX}" Y="{Binding ScreenY}"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsMajor}" Value="True">
                            <Setter TargetName="TxtMark" Property="Foreground" Value="Black"/>
                            <Setter TargetName="TxtMark" Property="FontWeight" Value="Bold"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMajor}" Value="False">
                            <Setter TargetName="TxtMark" Property="Foreground" Value="DimGray"/>
                            <Setter TargetName="TxtMark" Property="FontWeight" Value="Normal"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>