<Window x:Class="TrafficSim.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TrafficSim.ViewModels"
        xmlns:views="clr-namespace:TrafficSim.Views"
        xmlns:models="clr-namespace:TrafficSim.Models"
        Title="Редактор міста" Height="600" Width="900">

    <Window.DataContext>
        <vm:EditorViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseMenuAndResetCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EAEAEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <views:MapGridControl Grid.Row="0" Panel.ZIndex="0" />

        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" Panel.ZIndex="1">
            <StackPanel.RenderTransform>
                <TranslateTransform X="-66" />
            </StackPanel.RenderTransform>

            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMenuOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="0" Duration="0:0:0.2" DecelerationRatio="0.8"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="-66" Duration="0:0:0.2" AccelerationRatio="0.8"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <Border Width="66" Height="Auto" VerticalAlignment="Top" Background="#F5F5F5" BorderBrush="#CCC" BorderThickness="0,1,1,1" CornerRadius="0,5,5,0">
                <StackPanel Margin="0,10" HorizontalAlignment="Center">

                    <Button Command="{Binding ChangeModeCommand}" 
                            CommandParameter="{x:Static models:EditorMode.Select}" 
                            ToolTip="Вказівник (Select)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static models:EditorMode.Select}">
                                        <Setter Property="Background" Value="#EBF5FF"/>
                                        <Setter Property="BorderBrush" Value="#4DA6FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="↖" FontSize="22" Foreground="#333" FontWeight="Bold"/>
                    </Button>

                    <Button Command="{Binding ChangeModeCommand}" 
                            CommandParameter="{x:Static models:EditorMode.AddNode}" 
                            ToolTip="Створити вузол (Add Node)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static models:EditorMode.AddNode}">
                                        <Setter Property="Background" Value="#EBF5FF"/>
                                        <Setter Property="BorderBrush" Value="#4DA6FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Ellipse Width="16" Height="16" Fill="#E63946"/>
                    </Button>

                    <Button Command="{Binding ChangeModeCommand}" 
                            CommandParameter="{x:Static models:EditorMode.AddRoad}" 
                            ToolTip="Створити дорогу (Add Road)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static models:EditorMode.AddRoad}">
                                        <Setter Property="Background" Value="#EBF5FF"/>
                                        <Setter Property="BorderBrush" Value="#4DA6FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid Width="22" Height="16">
                            <Rectangle Fill="#666666" RadiusX="2" RadiusY="2"/>
                            <Line X1="2" Y1="8" X2="20" Y2="8" Stroke="White" StrokeThickness="2" StrokeDashArray="2,1" />
                        </Grid>
                    </Button>

                </StackPanel>
            </Border>

            <ToggleButton Width="25" Height="40" 
                          VerticalAlignment="Top" Margin="2,5,0,0"
                          Background="Transparent" BorderThickness="0" Cursor="Hand"
                          FontSize="20" FontWeight="Bold" Foreground="#666"
                          IsChecked="{Binding IsMenuOpen}">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Content" Value="&gt;"/>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="&lt;"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>
        </StackPanel>

        <StatusBar Grid.Row="1" Background="#EEE">
            <StatusBarItem>
                <TextBlock Text="Координати курсора: " FontWeight="Bold"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding LogicalCursorPosition.X, StringFormat='X: {0:F0}'}" Width="70"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding LogicalCursorPosition.Y, StringFormat='Y: {0:F0}'}" Width="70"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding Camera.Zoom, StringFormat='Масштаб: {0:F1}x'}" Width="100"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>